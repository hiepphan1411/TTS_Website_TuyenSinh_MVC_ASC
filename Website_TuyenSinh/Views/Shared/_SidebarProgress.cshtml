<aside class="sidebar-progress">
    <div class="sidebar-card">
        <div class="sidebar-title"><i class="bi bi-list-check me-1"></i>Mục lục đăng ký</div>

        <div class="text-center">
            <div class="progress-pct" id="df-sidebar-progress-pct">0%</div>
        </div>
        <div class="progress-bar-wrap">
            <div class="progress-bar-fill" id="df-sidebar-progress-fill" style="width:0%"></div>
        </div>
        <div class="progress-label text-center" id="df-sidebar-progress-label">0/0 bước hoàn thành</div>

        <ul class="step-list" id="df-sidebar-steps"></ul>
    </div>
</aside>

<script>
    (function () {
        function esc(s) {
            return s == null ? "" : String(s)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;");
        }

        function statusOf(idx, activeIdx, tab, isInit) {
            if (idx === activeIdx) return "active";
            if (isInit) return "pending"; 
            if (tab && tab.isCompleted) return "done";
            return "pending";
        }

        function subText(status) {
            if (status === "done") return "Đã hoàn thành";
            if (status === "active") return "Đang thực hiện";
            return "Chưa nhập";
        }

        window.dfUpdateSidebar = function (activeIdx, tabs, isInit) {
            tabs = Array.isArray(tabs) ? tabs : [];
            var total = tabs.length;
            var completed = tabs.filter(function (t) { return !!t.isCompleted; }).length;
            var pct = total ? Math.round((completed / total) * 100) : 0;


            var pctEl = document.getElementById("df-sidebar-progress-pct");
            var fillEl = document.getElementById("df-sidebar-progress-fill");
            var labelEl = document.getElementById("df-sidebar-progress-label");
            var listEl = document.getElementById("df-sidebar-steps");

            if (!isInit) {
                if (pctEl) pctEl.textContent = pct + "%";
                if (fillEl) fillEl.style.width = pct + "%";
                if (labelEl) labelEl.textContent = completed + "/" + total + " bước hoàn thành";
                if (!listEl) return;
            }

            var html = "";
            tabs.forEach(function (tab, idx) {
                var status = statusOf(idx, activeIdx, tab, isInit);
                var itemClass = status === "active" ? "is-active" : (status === "done" ? "is-done" : "");
                var label = tab && tab.tabLabel ? tab.tabLabel : ("Bước " + (idx + 1));

                html += ""
                    + "<li class='step-item " + itemClass + "' onclick='window.dfGoToTab && window.dfGoToTab(" + idx + ")'>"
                    + "<span class='step-badge " + status + "'>" + (idx + 1) + "</span>"
                    + "<div class='step-info'>"
                    + "<div class='step-info-title'>" + esc(label) + "</div>"
                    + "<div class='step-info-sub " + status + "'>" + subText(status) + "</div>"
                    + "</div>"
                    + "</li>";
            });

            listEl.innerHTML = html;
        };
    })();
</script>