<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>


    <!-- Library CSS -->

    <link href="~/Content/lib/themes/base/jquery-ui.css" rel="stylesheet" />
    <link href="~/Content/css/common.css" rel="stylesheet" />
    <link href="~/Content/lib/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/lib/kendo-ui.common.min.css" rel="stylesheet" />
    <link href="~/Content/lib/kendo.default.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/Content/css/dashboard-filter.css" />
    <link href="https://kendo.cdn.telerik.com/2016.3.1118/styles/kendo.common.min.css" rel="stylesheet" />
    <link href="https://kendo.cdn.telerik.com/2016.3.1118/styles/kendo.default.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" integrity="sha512-SfTiTlX6kk+qitfevl/7LibUOeJWlt9rbyDn92a1DqWOw9vWG2MFoays0sgObmWazO5BQPiFucnnEAjpAB+/Sw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="https://kit.fontawesome.com/6f955e325d.js" crossorigin="anonymous"></script>

    @RenderSection("Styles", required: false)
</head>
<body>

    @Html.Partial("_Header")

    @*@Html.Partial("_DashboardFilter")*@

    <div class="page-wrapper">
        <main class="content-area">
            @RenderBody()
        </main>
    </div>

    @Html.Partial("_Footer")

    <script src="~/Scripts/lib/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/lib/jquery-3.7.0.min.js"></script>
    <script src="https://kendo.cdn.telerik.com/2016.3.1118/js/kendo.all.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
