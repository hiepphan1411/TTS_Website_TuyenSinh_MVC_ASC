<div class="filter-section d-flex align-items-center gap-3 flex-wrap">

    <!-- Năm tuyển sinh -->
    <div class="filter-group">
        <label>Năm tuyển sinh <span class="text-danger">*</span></label>
        <div class="input-icon">
            <input type="date" class="form-control" />
            @*<i class="fa fa-calendar" aria-hidden="true"></i>*@
        </div>
    </div>

    <!-- Đợt tuyển sinh -->
    <div class="filter-group flex-grow-1">
        <label>Đợt tuyển sinh <span class="text-danger">*</span></label>
        <div class="multi-select">
            <span class="tag">2025 DHCQ <i class="bi bi-x"></i></span>
            <span class="tag">2025 - SDH - Thạc sĩ <i class="bi bi-x"></i></span>
            <span class="add-more">Chọn đợt tuyển sinh <i class="bi bi-plus"></i></span>
        </div>
    </div>

    <!-- Cơ sở -->
    <div class="filter-group">
        <label>Cơ sở</label>
        <div class="input-icon">
            <input type="text" class="form-control" placeholder="Chọn cơ sở" />
            <i class="bi bi-chevron-down"></i>
        </div>
    </div>

    <!-- Buttons -->
    <div class="d-flex align-items-end gap-2">
        <button class="btn btn-light btn-filter">
            <i class="bi bi-funnel"></i> Tùy chọn lọc
        </button>

        <button class="btn btn-primary">
            <i class="bi bi-search"></i> Tìm kiếm
        </button>

        <button class="btn btn-success">
            <i class="bi bi-arrow-repeat"></i> Đồng bộ
        </button>
    </div>

</div>

