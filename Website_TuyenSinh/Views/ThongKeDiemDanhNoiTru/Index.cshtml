@section scripts {
    <script>
        $(function () {

            var currentLoai = 1;
            var dataCache   = {};

            function getParam(loai) {
                return {
                    Thang:        parseInt($("#ddlThang").val()),
                    Nam:          parseInt($("#ddlNam").val()),
                    IDNhomDiaDiem: parseInt($("#ddlNhomDiaDiem").val()),
                    LoaiThongKe:  loai
                };
            }

            function loadData(loai, forceReload) {
                if (!forceReload && dataCache[loai]) {
                    renderTable(loai, dataCache[loai]);
                    return;
                }

                showLoading();

                $.ajax({
                    url:         "@Url.Action("GetThongKe", "ThongKeDiemDanhNoiTru")",
                    type:        "POST",
                    contentType: "application/json",
                    data:        JSON.stringify(getParam(loai)),
                    success: function (res) {
                        if (res.success) {
                            dataCache[loai] = res.data;
                            renderTable(loai, res.data);
                        } else {
                            showError(res.message || "Có lỗi xảy ra.");
                        }
                    },
                    error: function () {
                        showError("Không thể kết nối máy chủ.");
                    }
                });
            }



            //function renderTable(loai, data) {
            //    if (!data || data.length === 0) {
            //        $("#tabContent").html('<div class="empty-msg">Không có dữ liệu phù hợp.</div>');
            //        return;
            //    }

            //    var html = "<table><thead><tr>";

            //    Object.keys(data[0]).forEach(k => {
            //        html += "<th>" + k + "</th>";
            //    });

            //    html += "</tr></thead><tbody>";

            //    data.forEach(row => {
            //        html += "<tr>";
            //        Object.values(row).forEach(v => {
            //            html += "<td>" + (v ?? "") + "</td>";
            //        });
            //        html += "</tr>";
            //    });

            //    html += "</tbody></table>";

            //    $("#tabContent").html(html);
            //}

            function renderTable(loai, data) {
                if (!data || data.length === 0) {
                    $("#tabContent").html('<div class="empty-msg">Không có dữ liệu phù hợp.</div>');
                    return;
                }

                var html = "";

                switch (loai) {

                    case 1:
                        html += "<h3>Thống kê theo lớp</h3>";
                        html += "<table><thead><tr>"
                              + "<th>STT</th><th>Tên lớp</th>"
                              + "<th>Số lượng vắng</th><th>Ngày vắng</th>"
                              + "</tr></thead><tbody>";
                            data.forEach(row => {
                                html += "<tr>";
                                Object.values(row).forEach(v => {
                                    html += "<td>" + (v ?? "") + "</td>";
                                });
                                html += "</tr>";
                            });
                        html += "</tbody></table>";
                        break;

                    case 2:
                        html += "<h3>Thống kê theo sinh viên</h3>";
                        html += "<table><thead><tr>"
                              + "<th>STT</th><th>Mã SV</th><th>Họ và tên</th>"
                              + "<th>Lớp</th><th>Địa điểm</th><th>Dãy nhà</th>"
                              + "<th>Phòng</th><th>Số lần vắng</th><th>Ngày vắng</th>"
                              + "</tr></thead><tbody>";
                        $.each(data, function (i, row) {
                            html += "<tr>"
                                  + "<td>" + row.stt                  + "</td>"
                                  + "<td>" + row.maNoiTru              + "</td>"
                                  + "<td>" + row.hoVaTen               + "</td>"
                                  + "<td>" + row.tenLopHoc             + "</td>"
                                  + "<td>" + row.tenNhomDiaDiemPhong   + "</td>"
                                  + "<td>" + row.tenDayNha             + "</td>"
                                  + "<td>" + row.maPhong               + "</td>"
                                  + "<td>" + row.slVang                + "</td>"
                                  + "<td>" + row.ngayVang              + "</td>"
                                  + "</tr>";
                        });
                        html += "</tbody></table>";
                        break;

                    case 3:
                        html += "<h3>Thống kê theo phòng KTX</h3>";
                        html += "<table><thead><tr>"
                              + "<th>STT</th><th>Địa điểm phòng</th><th>Dãy nhà</th>"
                              + "<th>Phòng</th><th>Số SV vắng</th><th>Ngày vắng</th>"
                              + "</tr></thead><tbody>";
                        $.each(data, function (i, row) {
                            html += "<tr>"
                                  + "<td>" + row.stt                   + "</td>"
                                  + "<td>" + row.tenNhomDiaDiemPhong    + "</td>"
                                  + "<td>" + row.tenDayNha              + "</td>"
                                  + "<td>" + row.maPhong                + "</td>"
                                  + "<td>" + row.slsvVang               + "</td>"
                                  + "<td>" + row.ngayVang               + "</td>"
                                  + "</tr>";
                        });
                        html += "</tbody></table>";
                        break;
                }

                $("#tabContent").html(html);
            }

            function showLoading() {
                $("#tabContent").html('<div class="loading">Đang tải dữ liệu...</div>');
            }

            function showError(msg) {
                $("#tabContent").html('<div class="empty-msg" style="color:#c0392b;">' + msg + '</div>');
            }

            $(".tab").on("click", function () {
                $(".tab").removeClass("active");
                $(this).addClass("active");

                currentLoai = parseInt($(this).data("loai"));
                loadData(currentLoai, false);
            });

            $("#btnXem").on("click", function () {
                dataCache = {};
                loadData(currentLoai, true);
            });

            loadData(currentLoai, true);
        });
    </script>
}
