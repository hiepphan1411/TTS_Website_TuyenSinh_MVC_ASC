@{
    ViewBag.Title = "Thống kê điểm danh KTX";
}

@section styles {
    <link rel="stylesheet" href="~/Content/css/thongke-ktx-theo-lop.css" />

}

<div class="header">Thống kê điểm danh ký túc xá</div>

<div class="container">

    <div class="filter-box">
        <div class="filter-row">

            <label>Tháng</label>
            <select id="ddlThang">
                @for (int i = 1; i <= 12; i++)
                {
                    int year = DateTime.Now.Year;
                    string val = $"{i}/{year}";
                    bool selected = (i == DateTime.Now.Month);
                    <option value="@i" @(selected ? "selected" : "")>@($"{i:D2}/{year}")</option>
                }
            </select>

            <label>Năm</label>
            <select id="ddlNam">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                {
                    bool selected = (y == DateTime.Now.Year);
                    <option value="@y" @(selected ? "selected" : "")>@y</option>
                }
            </select>

            <label>Địa điểm phòng</label>
            <select id="ddlNhomDiaDiem">
                <option value="0">Tất cả</option>
                <option value="1">KTX cơ sở 1</option>
                <option value="2">KTX cơ sở 2</option>
            </select>

            <button class="btn-view" id="btnXem">Xem thống kê</button>
            <button class="btn-export" id="btnExcel">Xuất Excel</button>
        </div>
    </div>

    <div class="tabs">
        <div class="tab active" data-loai="1" id="tab-lop">Theo lớp</div>
        <div class="tab" data-loai="2" id="tab-sinhvien">Theo sinh viên</div>
        <div class="tab" data-loai="3" id="tab-phong">Theo phòng KTX</div>
    </div>

    <div class="table-box" id="tabContent">
        <div class="empty-msg">Chọn tháng / địa điểm rồi nhấn <strong>Xem thống kê</strong> hoặc click vào tab.</div>
    </div>

