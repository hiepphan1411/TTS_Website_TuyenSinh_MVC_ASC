@using TuyenSinh.Models.Entities
@using System.Text.Json
@using Newtonsoft.Json;

@model WebApplicationTest3.Models.TieuChiTuyenSinhViewModel
@{
    ViewBag.Title = "Đăng ký tuyển sinh";
    Layout = null;

    var doiTuongList = new List<string>
{
        "Chứng chỉ IELTS/TOEIC.",
        "Kết quả kỳ thi ACT.",
        "Kết quả kỳ thi SAT.",
        "Thí sinh là học sinh thuộc đội tuyển cấp tỉnh/thành phố hoặc đội tuyển của trường THPT chuyên trực thuộc các trường đại học tham gia kỳ thi học sinh giỏi quốc gia.",
        "Thí sinh ngoại quốc đủ điều kiện học tập hoặc theo diện cử tuyển.",
        "Thí sinh tham gia đạt giải các kỳ thi Tay nghề khu vực Asean và Quốc tế.",
        "Thí sinh tham gia đạt giải ở các cuộc thi Khoa học kỹ thuật.",
        "Tốt nghiệp trung cấp, cao đẳng, đại học trở lên."
    };

    var nganh = new List<Dictionary<string, string>>
{
        new Dictionary<string, string> { { "value", "CNTT" }, { "text", "Công nghệ thông tin" } },
        new Dictionary<string, string> { { "value", "TMDT" }, { "text", "Thương mại điện tử" } },
        new Dictionary<string, string> { { "value", "HH" }, { "text", "Công nghệ kỹ thuật hóa học" } }
    };

    var subjList = new List<string>()
{
        "Toán", "Văn", "Lý", "Hóa", "Sinh", "Lịch sử", "Địa lý", "Tiếng Anh", "Giáo dục Kinh tế và Pháp luật", "Giáo dục công dân"
    };

    var toHopList = new List<string>()
{
        "(A00): Toán, Lý, Hóa",
        "(D01): Toán, Tiếng Anh, Văn",
        "(B00): Toán, Hóa, Sinh",
        "(C00): Văn, Sử, Địa"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/Content/css/razor-logic-style.css" />
}

<div class="tab-container d-flex flex-column justify-content-center gap-3">
    @*<div class="tab-header d-flex flex-column gap-1 justify-content-start">
            <div class="tab-title fw-bold">Thông tin xét tuyển</div>
            <div class="tab-subtitle fw-semibold">Vui lòng chọn phương thức xét tuyển và nhập thông tin tương ứng cho từng phương thức.</div>
        </div>*@

    <div class="warning-title text-danger">
        <i class="fa fa-exclamation-circle" aria-hidden="true"></i>
        <span class="fw-semibold">Lưu ý: Vui lòng chọn hình thức xét tuyển đăng ký</span>
    </div>

    @foreach (var item in Model.TieuChiList)
    {
        <div class="phuongthuc-container">
            <div class="phuongthuc-header d-flex justify-content-between align-items-center">
                <div class="d-flex justify-content-start align-items-center gap-2">
                    <input type="checkbox" class="phuongthuc-checkbox" />
                    <span>@item.TenTieuChi</span>
                </div>
                <i class="fa fa-angle-down dropdown-icon" aria-hidden="true" style="transition: transform 0.3s;"></i>
            </div>

            @switch (item.IDCachNhapDiem ?? 0)
            {
                @*Cả năm Lớp 9*@
                case 1:
                    {
                        <div class="phuongthuc-body">
                            <div class="row">
                                <div class="col-md-4 d-flex flex-column w-fit gap-2">
                                    <label class="fw-semibold nv-label">Điểm tổng cộng</label>
                                    <input type="number" class="custom-input" style="min-width: 260px;" placeholder="Nhập điểm" id="CaNamLop09_01_@(item.Id)_01" />
                                </div>
                            </div>

                            <div class="d-flex flex-column gap-3" style="margin-top: 20px;">
                                @{
                                    ViewBag.IdPrefix = "CaNamLop09";
                                    ViewBag.IdTarget = "nguyen-vong-list-@item.Id";
                                    ViewBag.DataTemplate = "nv-template";
                                    ViewBag.Item = item;
                                    ViewBag.Nganh = nganh;
                                    ViewBag.TypeNum = 1;
                                    ViewBag.ToHopList = toHopList;
                                }
                                @Html.Partial("_NguyenVongSimple")
                            </div>
                        </div>
                        break;
                    }

                case 2:
                    {

                        break;
                    }

                @*Điểm HB 6 học kỳ*@
                @*Điểm TB 11, 12*@
                @*Điểm TB 10, 11, 12*@
                case 3:
                    {
                        <div class="phuongthuc-body">
                            <div>
                                <table class="table thpt-result-table mb-0">
                                    <thead>
                                        <tr>
                                            <th class="ps-2">MÔN</th>
                                            @{
                                                var str = item.Fields;
                                                var list = (str ?? "").Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries).Select(x => x.Trim()).ToList(); ;
                                                bool hasHK1 = list.Any(x => x.Contains("HK1"));

                                                List<string> result;
                                                if (hasHK1)
                                                {
                                                    result = list.Select(x =>
                                                    {
                                                        var hk = x.Contains("HK1") ? "HK1" : "HK2";
                                                        var lop = x.Substring(x.Length - 2);
                                                        return $"{hk} Lớp {lop}";
                                                    }).ToList();
                                                }
                                                else
                                                {
                                                    result = list.Select(x =>
                                                    {
                                                        var lop = x.Substring(x.Length - 2);
                                                        return $"CN Lớp {lop}";
                                                    }).ToList();
                                                }

                                                foreach (var lop in result)
                                                {
                                                    <th class="text-center">ĐIỂM @lop</th>
                                                }
                                            }
                                            <th class="text-center">ĐIỂM MÔN</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var subj in subjList)
                                        {
                                            <tr>
                                                <td>@subj</td>
