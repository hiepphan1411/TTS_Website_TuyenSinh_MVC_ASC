                                </div>
                                <div class="table-responsive">
                                    <table class="table thpt-result-table mb-0">
                                        <thead>
                                            <tr>
                                                <th style="width: 50px;">STT</th>
                                                <th>Tổ hợp môn</th>
                                                <th style="width: 140px; text-align: center">Tổng điểm tổ hợp môn</th>
                                                <th style="width: 110px; text-align: center">Tổng điểm</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < 2; i++)
                                            {
                                                <tr>
                                                    <td>@(i + 1)</td>
                                                    <td>@toHopList[i]</td>
                                                    <td class="text-center"><span class="score-pill">0.00 điểm</span></td>
                                                    <td class="text-center"><span class="score-pill">0.00 điểm</span></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="thpt-note text-danger">
                                <i class="fa fa-exclamation-circle" aria-hidden="true"></i>
                                Lưu ý: Điểm tổ hợp trên là điểm gốc, chưa nhân hệ số xét tuyển
                            </div>

                            <div class="d-flex flex-column gap-3" style="margin-top: 20px;">
                                @{
                                    ViewBag.IdPrefix = "KetQuaTHPTQuocGia";
                                    ViewBag.IdTarget = "nguyen-vong-list-thpt";
                                    ViewBag.DataTemplate = "nv-template-thpt";
                                    ViewBag.Item = item;
                                    ViewBag.Nganh = nganh;
                                    ViewBag.TypeNum = 1;
                                    ViewBag.ToHopList = toHopList;
                                }
                                @Html.Partial("_NguyenVongTHPT")
                            </div>
                        </div>
                        break;
                    }

                case 6:
                    {

                        break;
                    }

                case 7:
                    {

                        break;
                    }

                @*Tuyển thẳng*@
                case 8:
                    {
                        <div class="phuongthuc-body">
                            <div class="d-flex flex-column gap-1">
                                <span class="fw-semibold" style="font-size: 15px;">Đối tượng xét tuyển</span>
                                <ol class="list-doi-tuong d-flex flex-column gap-2 mb-0" style="padding-left: 10px !important;">
                                    @{
                                        for (int i = 0; i < doiTuongList.Count; i++)
                                        {
                                            <div class="d-flex gap-4 align-items-baseline">
                                                <input type="checkbox" class="doi-tuong-checkbox" id="CheckTuyenThang_@i" />
                                            <li>
                                                <span class="doi-tuong-span">@doiTuongList[i]</span>
                                            </li>
                                    </div>
                                }
                                    }
                                    </ol>
                                </div>

                                <div class="d-flex flex-column gap-3" style="margin-top: 20px;">
                                    @{
                                        ViewBag.IdPrefix = "TuyenThang";
                                        ViewBag.IdTarget = "nguyen-vong-list-tuyen-thang";
                                        ViewBag.DataTemplate = "nv-template";
                                        ViewBag.Item = item;
                                        ViewBag.Nganh = nganh;
                                        ViewBag.TypeNum = 1;
                                        ViewBag.ToHopList = toHopList;
                                    }
                                    @Html.Partial("_NguyenVongSimple")
                                </div>
                            </div>
                            break;
                        }

                    @*Từ xa*@
                    @*Liên thông*@
