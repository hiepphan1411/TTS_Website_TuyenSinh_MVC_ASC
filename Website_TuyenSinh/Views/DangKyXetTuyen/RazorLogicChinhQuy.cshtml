                                            </select>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="fw-semibold nv-label">Điểm cả năm lớp 12</label>
                                            <input type="number" class="custom-input" placeholder="Nhập điểm" />
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-md-4">
                                            <label class="fw-semibold nv-label">Tên học phần cơ sở</label>
                                            <input type="text" class="custom-input" placeholder="Nhập Tên học phần cơ sở" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="fw-semibold nv-label">Điểm môn</label>
                                            <input type="number" class="custom-input" placeholder="Nhập điểm" />
                                        </div>
                                        <div class="col-md-4 d-flex align-items-end">
                                            <div class="d-flex align-items-center gap-2">
                                                <input type="checkbox" id="diem-he-4-checkbox" />
                                                <label for="diem-he-4-checkbox" class="fw-semibold nv-label">Điểm hệ 4</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-md-4">
                                            <label class="fw-semibold nv-label">Tên học chuyên ngành</label>
                                            <input type="text" class="custom-input" placeholder="Nhập Tên học chuyên ngành" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="fw-semibold nv-label">Điểm môn</label>
                                            <input type="number" class="custom-input" placeholder="Nhập điểm" />
                                        </div>
                                        <div class="col-md-4 d-flex align-items-end">
                                            <div class="d-flex align-items-center gap-2">
                                                <input type="checkbox" id="diem-he-4-checkbox" />
                                                <label for="diem-he-4-checkbox" class="fw-semibold nv-label">Điểm hệ 4</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex flex-column gap-1">
                                    <span class="fw-bold text-uppercase" style="font-size: 14px; color: var(--color-text-light)">ĐỐI VỚI MÔN CHUYÊN MÔN CÓ NHIỀU HỌC PHẦN</span>
                                    <div class="hoc-phan-list-lienthong">
                                        <div class="row mb-2">
