                                </div>

                                <div class="d-grid">
                                    @for (int i = 0; i < subjList.Count; i++)
                                    {
                                        <div class="row mb-3">
                                            <div class="col-md-4">
                                                <label class="fw-semibold nv-label">Trường tham gia kỳ thi</label>
                                                <select class="custom-selection" style="min-width: 150px;" id="VSAT_01_@(item.IDCachNhapDiem)_TruongTG@(i)">
                                                    <option value="">Chọn trường tham gia kỳ thi</option>
                                                </select>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="fw-semibold nv-label">Số báo danh</label>
                                                <input type="text" class="custom-input" placeholder="Nhập Số báo danh" id="VSAT_01_@(item.IDCachNhapDiem)_SBD@(i)" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="fw-semibold nv-label">Điểm @subjList[i]</label>
                                                <input type="number" class="custom-input" placeholder="Nhập điểm @subjList[i]" id="VSAT_01_@(item.IDCachNhapDiem)_Diem@(i)" />
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="d-flex flex-column gap-3 nguyenvong-container mt-0">
                                    @{
                                        ViewBag.IdPrefix = "VSAT";
                                        ViewBag.IdTarget = "nguyen-vong-list-@item.Id";
                                        ViewBag.DataTemplate = "nv-template-thpt";
                                        ViewBag.Item = item;
                                        ViewBag.Nganh = nganh;
                                        ViewBag.TypeNum = 1;
                                        ViewBag.ToHopList = toHopList;
                                    }
                                    @Html.Partial("_NguyenVongTHPT")
                                </div>
                            </div>
                            break;
                        }

                    @*Lớp 12 và TN THPT*@
                    case 19:
                        {
                            <div class="phuongthuc-body">
                                <div class="row">
                                    <div class="row">
                                        <span class="fw-bold text-uppercase" style="font-size: 14px; color: var(--color-text-light)">ĐIỂM THI THPT</span>
                                    </div>
                                    <div class="row mt-2">
                                        <div class="col-md-3">
                                            <label class="fw-semibold nv-label">Môn 1</label>
                                            <select class="custom-selection" style="min-width: 150px;" id="DiemThiTHPT_01_@(item.IDCachNhapDiem)_Mon1_input">
                                                <option value="">Chọn môn 1</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="fw-semibold nv-label">Điểm môn 1</label>
                                            <input type="number" class="custom-input" placeholder="Nhập điểm môn 1" id="DiemThiTHPT_01_@(item.IDCachNhapDiem)_Mon1_input" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="fw-semibold nv-label">Môn 2</label>
                                            <select class="custom-selection" style="min-width: 150px;" id="DiemThiTHPT_01_@(item.IDCachNhapDiem)_Mon2_input">
                                                <option value="">Chọn môn 2</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="fw-semibold nv-label">Điểm môn 2</label>
                                            <input type="number" class="custom-input" placeholder="Nhập điểm môn 2" id="DiemThiTHPT_01_@(item.IDCachNhapDiem)_Mon2_input" />
                                        </div>
                                    </div>
                                </div>

                                <div class="row mt-3">
                                    <div class="row">
                                        <span class="fw-bold text-uppercase" style="font-size: 14px; color: var(--color-text-light)">ĐIỂM MÔN LỚP 12</span>
                                    </div>
                                    <div class="row mt-2">
                                        <div class="col-md-3">
                                            <label class="fw-semibold nv-label">Môn 3</label>
                                            <select class="custom-selection" style="min-width: 150px;" id="DiemThiTHPT_01_@(item.IDCachNhapDiem)_Lop12_input">
                                                <option value="">Chọn môn 3</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="fw-semibold nv-label">Điểm môn 3</label>
                                            <input type="number" class="custom-input" placeholder="Nhập điểm môn 3" id="DiemThiTHPT_01_@(item.IDCachNhapDiem)_Lop12_input" />
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex flex-column gap-3" style="margin-top: 20px;">
                                    @{
                                        ViewBag.IdPrefix = "12TNTHPT";
                                        ViewBag.IdTarget = "nguyen-vong-list-@item.Id";
                                        ViewBag.DataTemplate = "nv-template-thpt";
                                        ViewBag.Item = item;
                                        ViewBag.Nganh = nganh;
                                        ViewBag.TypeNum = 1;
                                        ViewBag.ToHopList = toHopList;
                                    }
                                    @Html.Partial("_NguyenVongTHPT")
                                </div>
                            </div>
                            break;
                        }
                }
        </div>
    }
</div>

