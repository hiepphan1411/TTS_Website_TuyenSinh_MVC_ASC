                                        </select>
                                    </div>
                                    <div>
                                        <label class="fw-semibold nv-label">Điểm đánh giá</label>
                                        <input type="number" class="custom-input" placeholder="Nhập điểm" id="DanhGiaNangLuc_01_@(item.Id)_NganhTotNghiepCK" />
                                    </div>
                                </div>

