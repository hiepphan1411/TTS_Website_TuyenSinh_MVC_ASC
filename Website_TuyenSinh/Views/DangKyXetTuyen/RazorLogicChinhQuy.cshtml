                                                               class="custom-input"
                                                               placeholder="Nhập điểm @subj"
                                                               id="@lop"
                                                               data-field="@lop"
                                                               data-matieuchi="@item.MaTieuChi" />
                                                    </td>

                                                }
                                                <td class="text-center"><span class="score-pill">0.00</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="thpt-table-block thpt-table-first">
                                <h6 class="thpt-table-title">Kết quả điểm các tổ hợp</h6>
                                <div class="table-responsive">
                                    <table class="table thpt-result-table mb-0">
                                        <thead>
                                            <tr>
                                                <th style="width: 50px;">STT</th>
                                                <th>Tổ hợp môn</th>
                                                <th style="width: 150px; text-align: center">Tổng điểm tổ hợp môn</th>
                                                <th style="width: 110px; text-align: center">Tổng điểm</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < toHopList.Count; i++)
                                            {
                                                <tr>
                                                    <td>@(i + 1)</td>
                                                    <td>@toHopList[i]</td>
                                                    <td class="text-center"><span class="score-pill">0.00 điểm</span></td>
                                                    <td class="text-center"><span class="score-pill">0.00 điểm</span></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="thpt-table-block">
                                <div class="thpt-table-title">
                                    <div>
                                        <i class="fa fa-star" aria-hidden="true" class="text-white fs-6"></i>
                                    </div>
                                    Tổ hợp môn có điểm cao nhất
                                </div>
                                <div class="table-responsive">
                                    <table class="table thpt-result-table mb-0">
                                        <thead>
                                            <tr>
                                                <th style="width: 50px;">STT</th>
                                                <th>Tổ hợp môn</th>
                                                <th style="width: 140px; text-align: center">Tổng điểm tổ hợp môn</th>
                                                <th style="width: 110px; text-align: center">Tổng điểm</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < 2; i++)
                                            {
                                                <tr>
                                                    <td>@(i + 1)</td>
                                                    <td>@toHopList[i]</td>
                                                    <td class="text-center"><span class="score-pill">0.00 điểm</span></td>
                                                    <td class="text-center"><span class="score-pill">0.00 điểm</span></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="thpt-note text-danger">
                                <i class="fa fa-exclamation-circle" aria-hidden="true"></i>
                                Lưu ý: Điểm tổ hợp trên là điểm gốc, chưa nhân hệ số xét tuyển
                            </div>

                            <div class="d-flex flex-column gap-3" style="margin-top: 20px;">
                                @{
                                    if ("201".Equals(item.MaTieuChi))
                                    {
                                        ViewBag.IdPrefix = "DiemTB101112";
                                    }
                                    else if ("202".Equals(item.MaTieuChi))
                                    {
                                        ViewBag.IdPrefix = "DiemTB1112";
                                    }
                                    else if ("Test_3".Equals(item.MaTieuChi))
                                    {
                                        ViewBag.IdPrefix = "DiemTBHB6HK";
                                    }
                                    ViewBag.IdTarget = "nguyen-vong-list-@item.Id";
                                    ViewBag.DataTemplate = "nv-template-thpt";
                                    ViewBag.Item = item;
                                    ViewBag.Nganh = nganh;
                                    ViewBag.TypeNum = 1;
                                    ViewBag.ToHopList = toHopList;
                                    ViewBag.ToHopMonJson = Model.ToHopMonJson;
                                }
                                @Html.Partial("_NguyenVongTHPT")
                            </div>
                        </div>
                        break;
                    }

                case 4:
                    {

                        break;
                    }

                @*Tốt nghiệp THPT*@
                case 5:
                    {
                        <div class="phuongthuc-body">
                            <div class="d-flex gap-3">
                                <div>
                                    <span class="fw-bold text-uppercase" style="font-size: 14px; color: var(--color-text-light)">Điểm thi THPT Quốc gia</span>
                                    <div class="d-grid thpt-score-grid gap-3" style="margin-top: 10px;">
                                        @for (int i = 0; i < subjList.Count; i++)
                                        {
                                            <div class="d-flex flex-column">
                                                <label class="fw-semibold nv-label">@subjList[i]</label>
                                                <input type="number" class="custom-input" placeholder="Nhập điểm @subjList[i]" id="KetQuaTHPTQuocGia_01_@(item.Id)_@(i+1)" />
                                            </div>

                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="thpt-table-block thpt-table-first">
                                <h6 class="thpt-table-title">Kết quả điểm các tổ hợp</h6>
                                <div class="table-responsive">
                                    <table class="table thpt-result-table mb-0">
                                        <thead>
                                            <tr>
                                                <th style="width: 50px;">STT</th>
                                                <th>Tổ hợp môn</th>
                                                <th style="width: 150px; text-align: center">Tổng điểm tổ hợp môn</th>
                                                <th style="width: 110px; text-align: center">Tổng điểm</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < toHopList.Count; i++)
                                            {
                                                <tr>
                                                    <td>@(i + 1)</td>
                                                    <td>@toHopList[i]</td>
                                                    <td class="text-center"><span class="score-pill">0.00 điểm</span></td>
                                                    <td class="text-center"><span class="score-pill">0.00 điểm</span></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="thpt-table-block">
                                <div class="thpt-table-title">
                                    <div>
                                        <i class="fa fa-star" aria-hidden="true" class="text-white fs-6"></i>
                                    </div>
