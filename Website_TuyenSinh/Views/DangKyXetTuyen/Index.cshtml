@{
    ViewData["Title"] = "Đăng ký xét tuyển";
    Layout = "~/Views/Shared/_LayoutTuyenSinh.cshtml";
}

@section styles {
    <link rel="stylesheet" href="~/Content/css/dang-ky-tuyen-sinh.css"/>    
}

<script id="form-config-data" type="application/json">
    @Html.Raw(ViewBag.FormConfigJson)
</script>

<div id="df-wrapper">
    <div id="df-loading" class="text-center py-5">
        <div class="spinner-border text-primary" role="status" style="width:2.5rem;height:2.5rem"></div>
        <p class="mt-3 text-muted small">Đang tải biểu mẫu…</p>
    </div>
</div>

<div class="modal fade" id="df-popup-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="df-popup-title">Tìm kiếm</h5>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/js/load-cau-hinh-tuyen-sinhv2.js">
    </script>
}
