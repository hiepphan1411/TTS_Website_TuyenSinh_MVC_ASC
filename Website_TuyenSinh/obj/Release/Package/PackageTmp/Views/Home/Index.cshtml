@{
    ViewBag.Title = "Trang chủ";
}

@section styles {
    <style>
        .card-register {
            transition: border-color 0.25s ease, transform 0.28s ease;
            cursor: pointer;
        }

            .card-register:hover {
                border-color: var(--primary-blue);
                transform: translateY(-5px);
            }

        .effect {
            transition: color 0.25s, transform 0.3s ease;
            display: inline-block;
        }

        .card-register:hover .effect {
            /*                color: #0F6E56;*/
            transform: scale(1.25) rotate(-8deg);
        }

        .card-register p:first-of-type {
            position: relative;
            display: inline-block;
        }

            .card-register p:first-of-type::after {
                content: '';
                position: absolute;
                bottom: -2px;
                left: 0;
                width: 0;
                height: 2px;
                background: var(--primary-blue);
                transition: width 0.4s ease;
            }

        .card-register:hover p:first-of-type::after {
            width: 100%;
        }

        .card-register .btn-outline-primary {
            transition: transform 0.25s ease, background 0.25s, color 0.25s;
        }

        .card-register:hover .btn-outline-primary {
            background: white;
            color: var(--primary-blue);
            border-color: var(--primary-blue);
            transform: scale(1.06);
        }

        .card-register svg {
            width: 13px;
            height: 13px;
            stroke: currentColor;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }


        /*Custom effect cho scroll*/
        .card-register.active-effect {
            border-color: var(--primary-blue);
            transform: translateY(-5px);
        }

            .card-register.active-effect .effect {
                transform: scale(1.25) rotate(-8deg);
            }

            .card-register.active-effect p:first-of-type::after {
                width: 100%;
            }

            .card-register.active-effect .btn-outline-primary {
                background: white;
                color: var(--primary-blue);
                border-color: var(--primary-blue);
                transform: scale(1.06);
            }
    </style>
}

<div class="banner">
    <div class="card-banner">
        <p>CỔNG THÔNG TIN TUYỂN SINH</p>
        <p>TUYỂN SINH ĐẠI HỌC</p>
        <p>CHÍNH QUY NĂM 2026</p>
        <p>Khám phá cơ hội học tập tại môi trường giáo dục hàng đầu, nơi kiến tạo tương lai và phát triển tiềm năng của bạn.</p>

        <div class="d-flex banner-btn justify-content-center gap-3 mt-4">
            <button class="btn-now-register">Đăng ký xét tuyển ngay</button>
            <a href="#" class="btn-detail">Xem chi tiết ngành học</a>
        </div>

        <div class="card-banner-footer">
            <span><i class="fa fa-graduation-cap"></i> Học bổng lên đến 20 tỷ</span>
            <span><i class="fa fa-briefcase"></i> Thực tập lương cao</span>
        </div>
    </div>
</div>

