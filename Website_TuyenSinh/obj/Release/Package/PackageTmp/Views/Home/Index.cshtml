<!-- Bootstrap JS -->
<script src="~/Scripts/lib/bootstrap.bundle.min.js"></script>
<script src="~/Scripts/lib/jquery-3.7.0.min.js"></script>
<script>
    $(document).ready(
        function () {
            $(".btn-now-register").click(function () {
                var targetPosition = $("#section-dk").offset().top;

                $("html, body").animate({
                    scrollTop: targetPosition
                }, 300, function () {
                    $(".card-register").addClass("active-effect");

                    setTimeout(function () {
                        $(".card-register").removeClass("active-effect");
                    }, 500);
                });
            });
        });

</script>